"----------------------------------------
" 検索
"----------------------------------------
" 検索するときに大文字小文字を区別しない
set ignorecase
" 検索結果をハイライト表示
set hlsearch

"----------------------------------------
"表示
"----------------------------------------
"行数を表示
set number
"tab=space4
set tabstop=4
"インデントを増やす時も減らす時もスペース４つ分に
set shiftwidth=4
"autoindentを有効にする
set autoindent
